 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Silver Layer - Products Processing\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook processes CDC events from the Bronze layer and merges them into the Silver products table with schema evolution support and **schema drift detection**.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Run helper notebooks\\n\",\n",
    "    \"%run ./helpers/NB_catalog_helpers\\n\",\n",
    "    \"%run ./helpers/NB_schema_drift_helpers\\n\",\n",
    "    \"%run ./helpers/NB_schema_contracts\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pyspark.sql.functions import col, coalesce, expr, from_json, to_timestamp, unbase64, row_number, current_timestamp, lit\\n\",\n",
    "    \"from pyspark.sql.types import IntegerType, LongType, StringType, StructField, StructType\\n\",\n",
    "    \"from pyspark.sql.window import Window\\n\",\n",
    "    \"import uuid\\n\",\n",
    "    \"\\n\",\n",
    "    \"dbutils.widgets.text(\\\"CATALOG\\\", \\\"workspace\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"BRONZE_SCHEMA\\\", \\\"bronze\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"BRONZE_TABLE\\\", \\\"products\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"SILVER_SCHEMA\\\", \\\"silver\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"SILVER_TABLE\\\", \\\"silver_products\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"CHECKPOINT_PATH\\\", \\\"/Volumes/workspace/default/mnt/checkpoints/products_silver\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"MONITORING_SCHEMA\\\", \\\"monitoring\\\")\\n\",\n",
    "    \"dbutils.widgets.text(\\\"SCHEMA_POLICY\\\", \\\"additive_only\\\")  # strict, additive_only, permissive\\n\",\n",
    "    \"dbutils.widgets.text(\\\"ALERT_CHANNEL\\\", \\\"log\\\")  # log, webhook, all\\n\",\n",
    "    \"dbutils.widgets.text(\\\"WEBHOOK_URL\\\", \\\"\\\")  # Optional Slack/Teams webhook\\n\",\n",
    "    \"\\n\",\n",
    "    \"CONFIG = {\\n\",\n",
    "    \"    \\\"catalog\\\": dbutils.widgets.get(\\\"CATALOG\\\"),\\n\",\n",
    "    \"    \\\"bronze_schema\\\": dbutils.widgets.get(\\\"BRONZE_SCHEMA\\\"),\\n\",\n",
    "    \"    \\\"bronze_table\\\": dbutils.widgets.get(\\\"BRONZE_TABLE\\\"),\\n\",\n",
    "    \"    \\\"silver_schema\\\": dbutils.widgets.get(\\\"SILVER_SCHEMA\\\"),\\n\",\n",
    "    \"    \\\"silver_table\\\": dbutils.widgets.get(\\\"SILVER_TABLE\\\"),\\n\",\n",
    "    \"    \\\"checkpoint_path\\\": dbutils.widgets.get(\\\"CHECKPOINT_PATH\\\"),\\n\",\n",
    "    \"    \\\"monitoring_schema\\\": dbutils.widgets.get(\\\"MONITORING_SCHEMA\\\"),\\n\",\n",
    "    \"    \\\"schema_policy\\\": dbutils.widgets.get(\\\"SCHEMA_POLICY\\\"),\\n\",\n",
    "    \"    \\\"alert_channel\\\": dbutils.widgets.get(\\\"ALERT_CHANNEL\\\"),\\n\",\n",
    "    \"    \\\"webhook_url\\\": dbutils.widgets.get(\\\"WEBHOOK_URL\\\"),\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Generate pipeline run ID for tracking\\n\",\n",
    "    \"PIPELINE_RUN_ID = str(uuid.uuid4())\\n\",\n",
    "    \"\\n\",\n",
    "    \"bronze_table_fqn = f\\\"{CONFIG['catalog']}.{CONFIG['bronze_schema']}.{CONFIG['bronze_table']}\\\"\\n\",\n",
    "    \"silver_schema_fqn = f\\\"{CONFIG['catalog']}.{CONFIG['silver_schema']}\\\"\\n\",\n",
    "    \"silver_table_fqn = f\\\"{silver_schema_fqn}.{CONFIG['silver_table']}\\\"\\n\",\n",
    "    \"drift_table_fqn = f\\\"{CONFIG['catalog']}.{CONFIG['monitoring_schema']}.schema_drift_log\\\"\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Initialize monitoring table for schema drift tracking\\n\",\n",
    "    \"create_schema_drift_table(spark, CONFIG['catalog'], CONFIG['monitoring_schema'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Initialize schema and table using helpers\\n\",\n",
    "    \"ensure_schema_exists(CONFIG['catalog'], CONFIG['silver_schema'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Check if table exists and create if needed\\n\",\n",
    "    \"existing_schema = get_existing_schema(spark, silver_table_fqn)\\n\",\n",
    "    \"if existing_schema is None:\\n\",\n",
    "    \"    create_silver_table_products(spark, silver_table_fqn)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(f\\\"Using existing Silver products table: {silver_table_fqn}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"# SCHEMA DRIFT VALIDATION\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Get expected schema contract\\n\",\n",
    "    \"expected_schema = get_schema_contract('silver.products')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Read a sample from Bronze to check actual schema\\n\",\n",
    "    \"bronze_sample = spark.read.format(\\\"delta\\\").load(bronze_table_fqn).limit(1)\\n\",\n",
    "    \"bronze_schema = bronze_sample.schema\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Validate schema with policy\\n\",\n",
    "    \"print(f\\\"Validating schema against contract with policy: {CONFIG['schema_policy']}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    is_valid, drift_result = validate_schema_with_policy(\\n\",\n",
    "    \"        spark,\\n\",\n",
    "    \"        expected_schema=expected_schema,\\n\",\n",
    "    \"        actual_schema=bronze_schema,\\n\",\n",
    "    \"        table_name=bronze_table_fqn,\\n\",\n",
    "    \"        drift_table=drift_table_fqn,\\n\",\n",
    "    \"        source_system=\\\"postgres_cdc\\\",\\n\",\n",
    "    \"        pipeline_run_id=PIPELINE_RUN_ID,\\n\",\n",
    "    \"        policy=CONFIG['schema_policy'],\\n\",\n",
    "    \"        alert_channel=CONFIG['alert_channel'],\\n\",\n",
    "    \"        webhook_url=CONFIG['webhook_url'] if CONFIG['webhook_url'] else None\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    if drift_result['has_drift']:\\n\",\n",
    "    \"        print(f\\\"⚠️ Schema drift detected: {drift_result['severity']}\\\")\\n\",\n",
    "    \"        if drift_result['added_columns']:\\n\",\n",
    "    \"            print(f\\\"  Added: {drift_result['added_columns']}\\\")\\n\",\n",
    "    \"        if drift_result['removed_columns']:\\n\",\n",
    "    \"            print(f\\\"  Removed: {drift_result['removed_columns']}\\\")\\n\",\n",
    "    \"        if drift_result['type_changes']:\\n\",\n",
    "    \"            print(f\\\"  Type changes: {drift_result['type_changes']}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"✅ Schema validation passed - no drift detected\\\")\\n\",\n",
    "    \"        \\n\",\n",
    "    \"except SchemaDriftException as e:\\n\",\n",
    "    \"    print(f\\\"🚨 PIPELINE BLOCKED: {e}\\\")\\n\",\n",
    "    \"    dbutils.notebook.exit(f\\\"Schema drift blocked pipeline: {e}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Read bronze stream with schema evolution enabled\\n\",\n",
    "    \"bronze_stream = (\\n\",\n",
    "    \"    spark.readStream\\n\",\n",
    "    \"    .option(\\\"mergeSchema\\\", \\\"true\\\")\\n\",\n",
    "    \"    .table(bronze_table_fqn)\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Schema for parsing Debezium JSON payload for products\\n\",\n",
    "    \"flexible_schema = StructType([\\n\",\n",
    "    \"    StructField(\\\"payload\\\", StructType([\\n\",\n",
    "    \"        StructField(\\\"before\\\", StructType([\\n\",\n",
    "    \"            StructField(\\\"id\\\", IntegerType()),\\n\",\n",
    "    \"            StructField(\\\"product_name\\\", StringType()),\\n\",\n",
    "    \"            StructField(\\\"weight\\\", StructType([\\n\",\n",
    "    \"                StructField(\\\"scale\\\", IntegerType()),\\n\",\n",
    "    \"                StructField(\\\"value\\\", StringType())\\n\",\n",
    "    \"            ])),\\n\",\n",
    "    \"            StructField(\\\"color\\\", StringType()),\\n\",\n",
    "    \"            StructField(\\\"created_at\\\", LongType()),\\n\",\n",
    "    \"            StructField(\\\"updated_at\\\", LongType())\\n\",\n",
    "    \"        ])),\\n\",\n",
    "    \"        StructField(\\\"after\\\", StructType([\\n\",\n",
    "    \"            StructField(\\\"id\\\", IntegerType()),\\n\",\n",
    "    \"            StructField(\\\"product_name\\\", StringType()),\\n\",\n",
    "    \"            StructField(\\\"weight\\\", StructType([\\n\",\n",
    "    \"                StructField(\\\"scale\\\", IntegerType()),\\n\",\n",
    "    \"                StructField(\\\"value\\\", StringType())\\n\",\n",
    "    \"            ])),\\n\",\n",
    "    \"            StructField(\\\"color\\\", StringType()),\\n\",\n",
    "    \"            StructField(\\\"created_at\\\", LongType()),\\n\",\n",
    "    \"            StructField(\\\"updated_at\\\", LongType())\\n\",\n",
    "    \"        ])),\\n\",\n",
    "    \"        StructField(\\\"op\\\", StringType()),\\n\",\n",
    "    \"        StructField(\\\"ts_ms\\\", LongType())\\n\",\n",
    "    \"    ]))\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"parsed = bronze_stream.select(from_json(col(\\\"value\\\"), flexible_schema).alias(\\\"data\\\")).select(\\\"data.payload.*\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Parse and transform CDC events\\n\",\n",
    "    \"events = parsed.select(\\n\",\n",
    "    \"    coalesce(col(\\\"after.id\\\"), col(\\\"before.id\\\")).alias(\\\"id\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.product_name\\\"), col(\\\"before.product_name\\\")).alias(\\\"product_name\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.weight.value\\\"), col(\\\"before.weight.value\\\")).alias(\\\"weight_raw\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.weight.scale\\\"), col(\\\"before.weight.scale\\\")).alias(\\\"weight_scale\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.color\\\"), col(\\\"before.color\\\")).alias(\\\"color\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.created_at\\\"), col(\\\"before.created_at\\\")).alias(\\\"created_at_raw\\\"),\\n\",\n",
    "    \"    coalesce(col(\\\"after.updated_at\\\"), col(\\\"before.updated_at\\\")).alias(\\\"updated_at_raw\\\"),\\n\",\n",
    "    \"    col(\\\"op\\\"),\\n\",\n",
    "    \"    to_timestamp((col(\\\"ts_ms\\\") / 1000).cast(\\\"double\\\")).alias(\\\"event_time\\\")\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Decode weight from base64 (Debezium numeric encoding)\\n\",\n",
    "    \"events = events.withColumn(\\\"weight_bytes\\\", unbase64(col(\\\"weight_raw\\\")))\\n\",\n",
    "    \"events = events.withColumn(\\\"weight_int\\\", expr(\\\"cast(conv(hex(weight_bytes), 16, 10) as double)\\\"))\\n\",\n",
    "    \"events = events.withColumn(\\\"weight\\\", expr(\\\"cast(weight_int / pow(10, weight_scale) as decimal(10,2))\\\"))\\n\",\n",
    "    \"events = events.withColumn(\\\"created_at\\\", to_timestamp((col(\\\"created_at_raw\\\") / 1000000).cast(\\\"double\\\")))\\n\",\n",
    "    \"events = events.withColumn(\\\"updated_at\\\", to_timestamp((col(\\\"updated_at_raw\\\") / 1000000).cast(\\\"double\\\")))\\n\",\n",
    "    \"\\n\",\n",
    "    \"events = events.select(\\n\",\n",
    "    \"    \\\"id\\\",\\n\",\n",
    "    \"    \\\"product_name\\\",\\n\",\n",
    "    \"    \\\"weight\\\",\\n\",\n",
    "    \"    \\\"color\\\",\\n\",\n",
    "    \"    \\\"created_at\\\",\\n\",\n",
    "    \"    \\\"updated_at\\\",\\n\",\n",
    "    \"    \\\"op\\\",\\n\",\n",
    "    \"    \\\"event_time\\\"\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def upsert_to_silver(batch_df, batch_id):\\n\",\n",
    "    \"    \\\"\\\"\\\"Upsert CDC events into Silver products table with schema evolution.\\\"\\\"\\\"\\n\",\n",
    "    \"    if not batch_df.take(1):\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Deduplicate: keep latest event per record\\n\",\n",
    "    \"    window = Window.partitionBy(\\\"id\\\").orderBy(col(\\\"event_time\\\").desc())\\n\",\n",
    "    \"    latest = (\\n\",\n",
    "    \"        batch_df\\n\",\n",
    "    \"        .withColumn(\\\"rn\\\", row_number().over(window))\\n\",\n",
    "    \"        .filter(col(\\\"rn\\\") == 1)\\n\",\n",
    "    \"        .drop(\\\"rn\\\")\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Get existing columns for schema evolution\\n\",\n",
    "    \"    existing_columns = get_existing_columns(spark, silver_table_fqn)\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Build dynamic merge clauses\\n\",\n",
    "    \"    core_fields = [\\\"id\\\", \\\"product_name\\\", \\\"weight\\\", \\\"color\\\", \\\"created_at\\\", \\\"updated_at\\\"]\\n\",\n",
    "    \"    update_set, insert_values = build_merge_clauses(\\n\",\n",
    "    \"        existing_columns, \\n\",\n",
    "    \"        core_fields,\\n\",\n",
    "    \"        include_inserted_dt=True,\\n\",\n",
    "    \"        include_updated_dt=True\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Execute merge using helper\\n\",\n",
    "    \"    delta_table = DeltaTable.forName(spark, silver_table_fqn)\\n\",\n",
    "    \"    execute_merge(spark, delta_table, latest, update_set, insert_values)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Start streaming write with schema evolution\\n\",\n",
    "    \"(\\n\",\n",
    "    \"    events.writeStream\\n\",\n",
    "    \"    .foreachBatch(upsert_to_silver)\\n\",\n",
    "    \"    .option(\\\"checkpointLocation\\\", CONFIG[\\\"checkpoint_path\\\"])\\n\",\n",
    "    \"    .option(\\\"mergeSchema\\\", \\\"true\\\")\\n\",\n",
    "    \"    .trigger(availableNow=True)\\n\",\n",
    "    \"    .start()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"✅ Silver products processing completed. Run ID: {PIPELINE_RUN_ID}\\\")\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"kernelspec\": {\n",
    "   \"display_name\": \"Python 3\",\n",
    "   \"language\": \"python\",\n",
    "   \"name\": \"python3\"\n",
    "  },\n",
    "  \"language_info\": {\n",
    "   \"name\": \"python\",\n",
    "   \"version\": \"3.10\"\n",
    "  }\n",
    " },\n",
    " \"nbformat\": 4,\n",
    " \"nbformat_minor\": 5\n",
    "}\n"

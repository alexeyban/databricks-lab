  "bootstrap_hook": null,
  "field_mappings": [
    {"target": "inventory_id", "source_paths": ["after.inventory_id", "before.inventory_id"]},
    {"target": "film_id", "source_paths": ["after.film_id", "before.film_id"]},
    {"target": "store_id", "source_paths": ["after.store_id", "before.store_id"]},
